# .env.example
# This file lists environment variables required by the server.
# Create a .env file in the same directory and populate it with your actual values.

# The URL of your Ollama instance.
# For Titan, this would typically be http://localhost:11434
# For Iron Chef or ArtforgeOG, it would be their respective IP addresses.
# OLLAMA_HOST=http://localhost:11434

# The name of the Ollama model to use.
# For Titan, this could be yi:34b
# For Iron Chef, this could be llama3
# For ArtforgeOG, this could be phi3
# OLLAMA_MODEL=llama3

# (Optional) API key for more advanced web search services like SerpAPI or Google Custom Search.
# googlesearch-python does not require an API key, but other services might.
# WEB_SEARCH_API_KEY=your_web_search_api_key_here